# =============================================
# ラベルン 環境変数テンプレート
# =============================================
# このファイルをコピーして .env を作成し、値を設定してください。
# Cloudflare Workersではシークレットは wrangler secret put で設定します。

# Gemini Flash API（翻訳用）
# Google AI Studio (https://aistudio.google.com/) で取得
GEMINI_API_KEY=

# Stripe（決済用）
# https://dashboard.stripe.com/apikeys で取得
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# JWT認証シークレット（任意の文字列、32文字以上推奨）
JWT_SECRET=

# Stripe Price ID（Stripeダッシュボードで作成後に設定）
# Products > 各プランのPrice IDをコピー
STRIPE_PRICE_LITE=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=
